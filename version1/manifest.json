{
  "manifest_version": 3,
  "name": "Rito Assistant",
  "version": "1.0.0",
  "description": "Minimal Chrome extension for sending commands from popup to background.",
  "permissions": ["scripting", "activeTab"],
  "host_permissions": ["https://api.groq.com/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
